#!/bin/bash
# 
# testing.sh
# Megan Lu
# COSC050, 26S
#
# Description: test cases for chill.c

# Zero arguments
./chill
  Temp   Wind  Chill
 -----  -----  -----
 -10.0    5.0  -22.3
 -10.0   10.0  -28.3
 -10.0   15.0  -32.2

   0.0    5.0  -10.5
   0.0   10.0  -15.9
   0.0   15.0  -19.4

  10.0    5.0    1.2
  10.0   10.0   -3.5
  10.0   15.0   -6.6

  20.0    5.0   13.0
  20.0   10.0    8.9
  20.0   15.0    6.2

  30.0    5.0   24.7
  30.0   10.0   21.2
  30.0   15.0   19.0

  40.0    5.0   36.5
  40.0   10.0   33.6
  40.0   15.0   31.8

# One argument tests:
# In range
./chill 32
  Temp   Wind  Chill
 -----  -----  -----
  32.0    5.0   27.1
  32.0   10.0   23.7
  32.0   15.0   21.6
# Lower boundary
./chill -99
  Temp   Wind  Chill
 -----  -----  -----
 -99.0    5.0 -126.8
 -99.0   10.0 -138.6
 -99.0   15.0 -146.2
# Upper boundary
./chill 50
  Temp   Wind  Chill
 -----  -----  -----
  50.0    5.0   48.2
  50.0   10.0   46.0
  50.0   15.0   44.6
# Out of range (below)
./chill -100
./chill: Temperature must be greater than or equal to -99.0 degrees Fahrenheit
# Out of range (above)
./chill 51
./chill: Temperature must be less than or equal to 50.0 degrees Fahrenheit

# Two arguments tests:
# Both in range
./chill 32.5 10
  Temp   Wind  Chill
 -----  -----  -----
  32.5   10.0   24.3
# Velocity lower boundary
./chill 6.02 0.5
  Temp   Wind  Chill
 -----  -----  -----
   6.0    0.5    9.8
# Only velocity out of range
./chill 3.14 0
./chill: Wind velocity must be grater than or equal to 0.5 MPH
# Only temperature out of range
./chill 55 1.5
./chill: Temperature must be less than or equal to 50.0 degrees Fahrenheit
# Both out of range
./chill 67 -3
./chill: Temperature must be less than or equal to 50.0 degrees Fahrenheit

# More than two arguments
./chill 1 2 3
usage: ./chill [temperature [velocity]] where temperature and velocity are floating-point numbers

exit 0
